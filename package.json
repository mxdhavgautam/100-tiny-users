{
  "name": "hundred-tiny-users",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "typecheck": "tsc --noEmit",
    "reset": "tsx eval/reset-demo.ts",
    "eval": "tsx eval/runner.ts",
    "demo:full": "tsx eval/demo-full.ts --keep-alive",
    "demo:full:once": "tsx eval/demo-full.ts",
    "patch:demo": "tsx eval/patcher.ts --mode demo --all",
    "patch:prompt": "tsx eval/patcher.ts --mode prompt --all",
    "report": "tsx eval/print-latest-report.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.55.1",
    "clsx": "^2.1.1",
    "next": "15.5.9",
    "react": "19.0.1",
    "react-dom": "19.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
